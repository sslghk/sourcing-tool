# Taobao Service URL
# For local development: http://localhost:8001
# For production: https://your-taobao-service.railway.app
TAOBAO_SERVICE_URL=http://localhost:8001

# OneBound API (for Taobao product data and image search)
ONEBOUND_API_KEY=your_onebound_api_key_here
ONEBOUND_API_SECRET=your_onebound_api_secret_here

# ImgBB API (for image hosting in image search)
IMGBB_API_KEY=your_imgbb_api_key_here

# AI Services (for product enrichment)
GEMINI_API_KEY=your_gemini_api_key_here

# NextAuth.js Secret (generate with: openssl rand -base64 32)
AUTH_SECRET=your_auth_secret_here
